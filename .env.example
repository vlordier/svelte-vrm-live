# Copy this file to .env and configure your preferred LLM provider
# The system will AUTO-DETECT which provider to use based on your configuration!
# Just uncomment ONE of the options below:

# =============================================================================
# OPTION 1: Google Gemini (Cloud-based, requires API key)
# =============================================================================
# Uncomment to use Google Gemini:
# GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# OPTION 2: Ollama (Local, free)
# =============================================================================
# Uncomment to use Ollama:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:latest

# =============================================================================
# OPTION 3: LM Studio (Local, free) - DEFAULT
# =============================================================================
# Uncomment to use LM Studio (or leave as default):
# Note: LM Studio requires WebSocket URL (ws://) not HTTP
LMSTUDIO_BASE_URL=ws://localhost:1234
LMSTUDIO_MODEL=llama-3.2-1b-instruct

# =============================================================================
# Advanced: Manual Override (optional)
# =============================================================================
# Force a specific provider (overrides auto-detection):
# LLM_PROVIDER=google

# =============================================================================
# TTS (Text-to-Speech) Configuration
# =============================================================================
# OPTION 1: Kokoro TTS (Local, high-quality) - DEFAULT
# Uncomment to customize Kokoro TTS (or leave as default):
TTS_PROVIDER=kokoro
KOKORO_VOICE=af_bella
KOKORO_MODEL_ID=onnx-community/Kokoro-82M-ONNX
KOKORO_DTYPE=q4
# KOKORO_DEVICE=cpu  # Auto-detected: 'cpu' for server, 'wasm' for browser

# OPTION 2: Browser TTS (Native browser speech synthesis)
# Uncomment to use browser TTS:
# TTS_PROVIDER=browser
# BROWSER_VOICE=default

# =============================================================================
# STT (Speech-to-Text) Configuration
# =============================================================================
# VAD (Voice Activity Detection) settings
VAD_POSITIVE_THRESHOLD=0.8
VAD_NEGATIVE_THRESHOLD=0.35
VAD_MIN_SPEECH_FRAMES=5

# Whisper ASR settings
WHISPER_MODEL_ID=Xenova/whisper-tiny.en
WHISPER_DTYPE=q4
WHISPER_DEVICE=wasm
WHISPER_LANGUAGE=en
WHISPER_TASK=transcribe

# =============================================================================
# Other Configuration
# =============================================================================
# VRM Avatar Model (default: punk.vrm)
VRM_MODEL=cali_girl2.vrm

# ElevenLabs Text-to-Speech (optional)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key