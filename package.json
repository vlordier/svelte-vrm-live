{
	"name": "threlte-live",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"security:audit": "npm audit",
		"security:fix": "npm audit fix",
		"test": "vitest",
		"test:run": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"test:all": "npm run format:check && npm run lint && npm run check && npm run test:run && npm run security:audit",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:report": "playwright show-report",
		"test:llm": "node scripts/test-llm.js",
		"test:tts": "node scripts/test-tts.js",
		"precommit": "lint-staged"
	},
	"devDependencies": {
		"@eslint/js": "^9.33.0",
		"@playwright/test": "^1.54.2",
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.7.0",
		"@testing-library/svelte": "^5.2.8",
		"@testing-library/user-event": "^14.6.1",
		"@types/three": "^0.167.1",
		"@typescript-eslint/eslint-plugin": "^8.39.1",
		"@typescript-eslint/parser": "^8.39.1",
		"@vitest/coverage-v8": "^3.2.4",
		"@vitest/ui": "^3.2.4",
		"eslint": "^9.33.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.11.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.1.5",
		"playwright": "^1.54.2",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.2.6",
		"vitest": "^3.2.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@lmstudio/sdk": "^1.5.0",
		"@pixiv/three-vrm": "^3.4.0",
		"@pixiv/three-vrm-animation": "^3.4.0",
		"@sveltejs/adapter-cloudflare": "^7.0.5",
		"@threlte/core": "^8.0.2",
		"@threlte/extras": "^9.1.4",
		"@types/franc": "^5.0.3",
		"@types/node": "^22.15.17",
		"cld3-asm": "^4.0.0",
		"dotenv": "^16.5.0",
		"franc": "^6.2.0",
		"kokoro-js": "^1.2.1",
		"langdetect": "^0.2.1",
		"ollama": "^0.5.17",
		"three": "^0.176.0"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,css,html}": [
			"prettier --write"
		]
	}
}
